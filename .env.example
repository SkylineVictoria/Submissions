# Supabase (get from https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vite / Frontend (same project - anon key is safe for client-side)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Emergency maintenance — when true, production shows a maintenance screen and loads zero Supabase client code.
# Set in Vercel/hosting env and redeploy. Remove or set false when database is healthy again.
VITE_MAINTENANCE_MODE=false

# PDF server (optional - defaults to http://localhost:3001 when running locally)
VITE_PDF_API_URL=http://localhost:3001

# Firebase (Web Push via FCM) - public config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Firebase Web Push certificate key (VAPID)
VITE_FIREBASE_VAPID_KEY=
